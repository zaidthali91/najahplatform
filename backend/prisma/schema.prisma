// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum TrackType {
  DAYTIME
  EVENING
}

enum SubjectCode {
  INELT    // English
  INCPT    // Computer
  ARABIC   // Arabic
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ExamMode {
  OFFICIAL     // محاكاة رسمية
  PRACTICE     // تدريب حر
  SPEED_CHALLENGE // تحدي سريع
  WEAKNESS     // نقاط الضعف
  ADAPTIVE     // ذكي تكيفي
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

// Models
model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  fullName        String?
  trackType       TrackType @default(DAYTIME)
  walletBalance   Decimal   @default(0) @db.Decimal(10, 2)
  xpPoints        Int       @default(0)
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastStudyDate   DateTime?
  emailVerified   Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  examAttempts    ExamAttempt[]
  transactions    Transaction[]
  pdfAnalyses     PdfAnalysis[]
  studyPlans      StudyPlan[]
  achievements    UserAchievement[]

  @@index([email])
  @@index([trackType])
}

model Subject {
  id              Int         @id @default(autoincrement())
  nameAr          String      // "اللغة الإنجليزية"
  nameEn          String      // "English Language"
  code            SubjectCode @unique
  passingScore    Decimal     @db.Decimal(5, 2) // درجة الاجتياز
  durationMinutes Int         @default(60)
  questionCount   Int
  description     String?
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())

  // Relations
  questions       Question[]
  examAttempts    ExamAttempt[]

  @@index([code, isActive])
}

model Question {
  id              String     @id @default(uuid())
  subjectId       Int
  content         String     @db.Text
  options         Json       // [{text: "A", isCorrect: true}, ...]
  explanation     String?    @db.Text
  difficulty      Difficulty
  tags            String[]   // ["grammar", "excel", "نحو"]
  sourceYear      Int?
  sourceExam      String?    // "2024-الدور الأول"
  aiGenerated     Boolean    @default(false)
  usageCount      Int        @default(0)
  correctRate     Decimal?   @db.Decimal(5, 2)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  subject         Subject    @relation(fields: [subjectId], references: [id])
  examAttempts    ExamQuestionAnswer[]

  @@index([subjectId, difficulty])
  @@index([tags])
  @@index([aiGenerated])
}

model ExamAttempt {
  id                String   @id @default(uuid())
  userId            String
  subjectId         Int
  mode              ExamMode
  score             Decimal? @db.Decimal(5, 2)
  totalQuestions    Int
  correctAnswers    Int?
  timeTakenSeconds  Int?
  startedAt         DateTime @default(now())
  completedAt       DateTime?
  isPaid            Boolean  @default(false)
  costDeducted      Decimal  @default(0) @db.Decimal(10, 2)

  // Relations
  user              User     @relation(fields: [userId], references: [id])
  subject           Subject  @relation(fields: [subjectId], references: [id])
  answers           ExamQuestionAnswer[]

  @@index([userId, completedAt])
  @@index([subjectId, startedAt])
}

model ExamQuestionAnswer {
  id           String  @id @default(uuid())
  examAttemptId String
  questionId   String
  selectedOption Int?   // index of selected option
  isCorrect    Boolean?
  timeSpent    Int?     // seconds spent on this question

  examAttempt  ExamAttempt @relation(fields: [examAttemptId], references: [id], onDelete: Cascade)
  question     Question    @relation(fields: [questionId], references: [id])

  @@unique([examAttemptId, questionId])
  @@index([questionId])
}

model Transaction {
  id                String            @id @default(uuid())
  userId            String
  amount            Decimal           @db.Decimal(10, 2)
  currency          String            @default("IQD")
  type              TransactionType
  description       String
  paymentGatewayRef String?
  status            TransactionStatus @default(PENDING)
  metadata          Json?             // extra data like {items: [...]}
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user              User              @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status])
}

model PdfAnalysis {
  id              String   @id @default(uuid())
  userId          String
  fileName        String
  fileUrl         String   // S3 path
  fileSize        Int      // bytes
  extractedText   String?  @db.Text
  aiSummary       String?  @db.Text
  generatedQuestions Json? // questions generated from PDF
  processingStatus String  @default("pending") // pending, processing, completed, failed
  errorMessage    String?
  processedAt     DateTime?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([processingStatus])
}

model StudyPlan {
  id            String   @id @default(uuid())
  userId        String
  targetDate    DateTime
  dailyHours    Int
  subjects      Json     // [{subjectId, priority, weakTopics: []}]
  schedule      Json     // weekly schedule
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id])
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String
  achievementKey String  // "first_exam", "streak_7", "perfect_score"
  earnedAt      DateTime @default(now())
  metadata      Json?

  user          User     @relation(fields: [userId], references: [id])

  @@unique([userId, achievementKey])
}


// backend/prisma/schema.prisma - إضافات جديدة

// 📊 جدول نشاط الدراسة اليومي
model DailyStudyActivity {
  id            String   @id @default(uuid())
  userId        String
  date          DateTime @db.Date // YYYY-MM-DD
  questionsAnswered Int @default(0)
  correctAnswers    Int @default(0)
  timeSpentMinutes  Int @default(0)
  xpEarned          Int @default(0)
  subjectsCovered   String[] // ["INELT", "INCPT"]
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, date])
  @@index([userId, date])
}

// 🏆 جدول الإنجازات والشارات
model Achievement {
  id            String   @id @default(uuid())
  key           String   @unique // "first_exam", "streak_7", "perfect_score"
  nameAr        String   // "أول امتحان"
  nameEn        String   // "First Exam"
  description   String   @db.Text
  icon          String   // "🎯", "🔥", "⭐"
  xpReward      Int      @default(50)
  requirement   Json     // {type: "exam_count", value: 1}
  
  userAchievements UserAchievement[]
}

model UserAchievement {
  id              String   @id @default(uuid())
  userId          String
  achievementId   String
  earnedAt        DateTime @default(now())
  progress        Int      @default(0) // للشارات التدريجية
  isClaimed       Boolean  @default(false)
  
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement     Achievement @relation(fields: [achievementId], references: [id])
  
  @@unique([userId, achievementId])
}

// 🌍 جدول المتصدرين (مُحدَّث يومياً عبر Cron Job)
model LeaderboardEntry {
  id              String   @id @default(uuid())
  userId          String
  period          String   // "daily", "weekly", "monthly", "all_time"
  periodStart     DateTime @db.Date
  periodEnd       DateTime @db.Date
  xpEarned        Int
  examsCompleted  Int
  avgScore        Decimal? @db.Decimal(5,2)
  rank            Int
  province        String?  // للمحافظات العراقية
  
  user            User     @relation(fields: [userId], references: [id])
  
  @@index([period, periodStart, rank])
  @@index([userId, period])
}

// 🔔 جدول الإشعارات
model Notification {
  id            String   @id @default(uuid())
  userId        String
  type          String   // "achievement", "streak", "exam_reminder", "system"
  title         String
  message       String   @db.Text
  link          String?  // رابط داخلي
  isRead        Boolean  @default(false)
  priority      String   @default("normal") // low, normal, high
  createdAt     DateTime @default(now())
  readAt        DateTime?
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, isRead, createdAt])
}